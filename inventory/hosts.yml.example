all:
  children:
    cisco_routers:
      hosts:
        R1:
          ansible_host: 172.17.0.11
        R2:
          ansible_host: 172.17.0.12
      vars:
        ansible_user: admin
        ansible_password: YOUR_PASSWORD_HERE
        ansible_connection: network_cli
        ansible_network_os: ios
        ansible_ssh_common_args: '-o KexAlgorithms=+diffie-hellman-group14-sha1 -o HostKeyAlgorithms=+ssh-rsa -o Ciphers=+aes128-cbc,aes192-cbc,aes256-cbc,3des-cbc -o MACs=+hmac-sha1,hmac-md5 -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'